{
  "name": "daily-astrology-os",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node dev-server.mjs",
    "dev:memory": "node services/memory-graph-engine/src/index.js",
    "dev:patterns": "node services/pattern-detection-service/src/index.js",
    "dev:narrative": "node services/narrative-service/src/index.js",
    "dev:rag": "node services/research-rag-engine/src/index.js",
    "dev:orchestrator": "node services/orchestrator/src/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test:memory": "node --test services/memory-graph-engine/test/scoring.test.js services/memory-graph-engine/test/engine.test.js",
    "test:patterns": "node --test services/pattern-detection-service/test/engine.test.js services/pattern-detection-service/test/reporting.test.js services/pattern-detection-service/test/server.test.js",
    "test:narrative": "node --test services/narrative-service/test/engine.test.js services/narrative-service/test/reporting.test.js services/narrative-service/test/server.test.js",
    "test:rag": "node --test services/research-rag-engine/test/engine.test.js services/research-rag-engine/test/evaluation.test.js services/research-rag-engine/test/server.test.js",
    "test:orchestrator": "node --test services/orchestrator/test/engine.test.js services/orchestrator/test/server.test.js"
  },
  "dependencies": {
    "openai": "^5.13.0",
    "pg": "^8.13.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "neo4j-driver": "^5.27.0",
    "vite": "^7.1.3"
  }
}
